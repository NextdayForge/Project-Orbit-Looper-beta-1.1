# 開発者向け（expo start / 開発ビルドのみ）。本番ユーザー向けアプリには含めないでください。
# Google AI Studio: https://aistudio.google.com/apikey
# プロキシ未設定時のローカル開発用（任意）
EXPO_PUBLIC_GEMINI_API_KEY=your_api_key_here

# Orbit Looper AI プロキシ（ベータ APK 推奨）— docs/CLOUD_AI_PROXY.md 参照
# EXPO_PUBLIC_LOOPER_AI_PROXY_URL=https://looper-gemini-proxy.your-subdomain.workers.dev
# EXPO_PUBLIC_LOOPER_AI_BETA_TOKEN=your-beta-token

# 任意（デフォルト: gemini-2.5-flash）
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash
