{
  "name": "orbit-looper",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --host lan --port 8080",
    "start:tunnel": "expo start --host tunnel --port 8080",
    "start:clear": "expo start -c --host lan --port 8080",
    "start:clear:tunnel": "expo start -c --host tunnel --port 8080",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "build:ios": "eas build --platform ios --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:android:preview": "eas build --platform android --profile preview",
    "submit:ios": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.0",
    "expo-constants": "~18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-notifications": "^0.32.17",
    "expo-sensors": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "eas-cli": "^16.28.0",
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.0"
  },
  "private": true
}
